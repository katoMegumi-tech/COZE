{
  "openapi": "3.0.1",
  "info": {
    "title": "API Documentation",
    "version": "1.0"
  },
  "paths": {
    "/api/copywriting/generate": {
      "post": {
        "summary": "生成文案",
        "description": "生成文案",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "productServiceName"
                ],
                "type": "object",
                "properties": {
                  "fileIds": {
                    "type": "array",
                    "description": "文件 ID 列表（从文件上传接口获取）",
                    "items": {
                      "type": "string"
                    }
                  },
                  "productServiceName": {
                    "type": "string",
                    "description": "产品/服务名称"
                  },
                  "coreSellingPoints": {
                    "type": "string",
                    "description": "核心卖点"
                  },
                  "targetAudience": {
                    "type": "string",
                    "description": "目标受众"
                  },
                  "usageScenario": {
                    "type": "string",
                    "description": "使用场景"
                  },
                  "copyType": {
                    "type": "string",
                    "description": "文案类型"
                  },
                  "toneStyle": {
                    "type": "string",
                    "description": "语气风格"
                  },
                  "wordCountLimit": {
                    "type": "string",
                    "description": "字数限制"
                  },
                  "structurePreference": {
                    "type": "string",
                    "description": "结构偏好"
                  },
                  "keywords": {
                    "type": "string",
                    "description": "关键词"
                  },
                  "forbiddenWords": {
                    "type": "string",
                    "description": "禁用词"
                  },
                  "referenceLink": {
                    "type": "string",
                    "description": "参考链接"
                  }
                },
                "description": ""
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": ""
                    },
                    "message": {
                      "type": "string",
                      "description": ""
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "content": {
                          "type": "string",
                          "description": "生成的文案内容（Group1 字段）"
                        },
                        "outputLinks": {
                          "type": "array",
                          "description": "输出链接列表",
                          "items": {
                            "type": "string"
                          }
                        },
                        "status": {
                          "type": "string",
                          "description": "状态：SUCCESS(成功)、FAILED(失败)"
                        },
                        "errorMessage": {
                          "type": "string",
                          "description": "错误信息（失败时返回）"
                        },
                        "debugData": {
                          "type": "string",
                          "description": "调试数据（完整响应）"
                        }
                      },
                      "description": ""
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/coze/workflow/async": {
      "post": {
        "summary": "异步生成视频",
        "description": "异步生成视频",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "fileId"
                ],
                "type": "object",
                "properties": {
                  "fileId": {
                    "type": "string",
                    "description": "文件 ID（从文件上传接口获取）"
                  },
                  "productName": {
                    "type": "string",
                    "description": "产品名称（可选）"
                  },
                  "productDesc": {
                    "type": "string",
                    "description": "产品描述（可选）"
                  },
                  "productFeatures": {
                    "type": "string",
                    "description": "产品特点"
                  },
                  "productPrice": {
                    "type": "string",
                    "description": "产品价格"
                  },
                  "videoAspectRatio": {
                    "type": "string",
                    "description": "视频宽高比"
                  },
                  "videoLength": {
                    "maximum": 12,
                    "minimum": 5,
                    "type": "integer",
                    "description": "视频长度（秒）"
                  },
                  "videoNum": {
                    "maximum": 1,
                    "minimum": 1,
                    "type": "integer",
                    "description": "生成数量（固定为 1）"
                  },
                  "videoResolution": {
                    "type": "string",
                    "description": "视频清晰度"
                  },
                  "videoScene": {
                    "type": "string",
                    "description": "视频场景"
                  },
                  "videoStyle": {
                    "type": "string",
                    "description": "视频风格"
                  },
                  "videoSubtitle": {
                    "type": "boolean",
                    "description": "是否添加字幕"
                  }
                },
                "description": "工作流请求参数"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "任务ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": ""
                    },
                    "message": {
                      "type": "string",
                      "description": ""
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "key": {
                          "type": "string"
                        }
                      },
                      "description": ""
                    }
                  },
                  "description": "任务ID"
                }
              }
            }
          }
        }
      }
    },
    "/api/coze/workflow/status/{taskId}": {
      "get": {
        "summary": "查询任务状态",
        "description": "查询任务状态",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "description": "任务ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "任务状态",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": ""
                    },
                    "message": {
                      "type": "string",
                      "description": ""
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "taskId": {
                          "type": "string",
                          "description": "任务 ID"
                        },
                        "status": {
                          "type": "string",
                          "description": "任务状态：PENDING(等待中)、PROCESSING(生成中)、COMPLETED(已完成)、FAILED(失败)"
                        },
                        "progress": {
                          "type": "integer",
                          "description": "进度百分比 0-100"
                        },
                        "message": {
                          "type": "string",
                          "description": "状态描述"
                        },
                        "videoUrls": {
                          "type": "array",
                          "description": "视频 URL 列表（完成时返回）",
                          "items": {
                            "type": "string"
                          }
                        },
                        "errorMessage": {
                          "type": "string",
                          "description": "错误信息（失败时返回）"
                        }
                      },
                      "description": ""
                    }
                  },
                  "description": "任务状态"
                }
              }
            }
          }
        }
      }
    },
    "/api/upload/coze": {
      "post": {
        "summary": "上传文件到 Coze",
        "description": "上传文件到 Coze",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "要上传的文件",
                    "format": "binary"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "上传结果，包含文件 ID 等信息",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": ""
                    },
                    "message": {
                      "type": "string",
                      "description": ""
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "文件 ID"
                        },
                        "bytes": {
                          "type": "integer",
                          "description": "文件大小（字节）",
                          "format": "int64"
                        },
                        "fileName": {
                          "type": "string",
                          "description": "文件名称"
                        },
                        "createdAt": {
                          "type": "integer",
                          "description": "上传时间（Unix 时间戳，秒）",
                          "format": "int64"
                        }
                      },
                      "description": ""
                    }
                  },
                  "description": "上传结果，包含文件 ID 等信息"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "文案生成响应": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "生成的文案内容（Group1 字段）"
          },
          "outputLinks": {
            "type": "array",
            "description": "输出链接列表",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "description": "状态：SUCCESS(成功)、FAILED(失败)"
          },
          "errorMessage": {
            "type": "string",
            "description": "错误信息（失败时返回）"
          },
          "debugData": {
            "type": "string",
            "description": "调试数据（完整响应）"
          }
        },
        "description": ""
      },
      "任务状态响应": {
        "type": "object",
        "properties": {
          "taskId": {
            "type": "string",
            "description": "任务 ID"
          },
          "status": {
            "type": "string",
            "description": "任务状态：PENDING(等待中)、PROCESSING(生成中)、COMPLETED(已完成)、FAILED(失败)"
          },
          "progress": {
            "type": "integer",
            "description": "进度百分比 0-100"
          },
          "message": {
            "type": "string",
            "description": "状态描述"
          },
          "videoUrls": {
            "type": "array",
            "description": "视频 URL 列表（完成时返回）",
            "items": {
              "type": "string"
            }
          },
          "errorMessage": {
            "type": "string",
            "description": "错误信息（失败时返回）"
          }
        },
        "description": ""
      },
      "com.cqie.demo01.dto.response.CozeFileUploadResponse.FileData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "文件 ID"
          },
          "bytes": {
            "type": "integer",
            "description": "文件大小（字节）",
            "format": "int64"
          },
          "fileName": {
            "type": "string",
            "description": "文件名称"
          },
          "createdAt": {
            "type": "integer",
            "description": "上传时间（Unix 时间戳，秒）",
            "format": "int64"
          }
        },
        "description": ""
      }
    }
  }
}